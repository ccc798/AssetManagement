# Auto detect text files and perform LF normalization
* text=auto

# Custom for Visual Studio
*.cs     text diff=csharp
*.sln    text eol=crlf
*.csproj text eol=crlf
*.vbproj text eol=crlf
*.fsproj text eol=crlf
*.sql    text eol=crlf

# Standard to LF line endings
*.dart           text eol=lf
*.yaml           text eol=lf
*.yml            text eol=lf
*.md             text eol=lf
*.json           text eol=lf
*.xml            text eol=lf
*.ps1            text eol=crlf
*.sh             text eol=lf

# Flutter specific
*.dart           text eol=lf
*.swift          text eol=lf
*.kt             text eol=lf
*.java           text eol=lf
*.cpp            text eol=lf
*.h              text eol=lf
*.rc             text eol=crlf

# Binary files
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.ico            binary
*.icns           binary
*.svg            text eol=lf

# Build artifacts
*.apk            binary
*.aab            binary
*.ipa            binary
*.zip            binary
*.tar.gz         binary